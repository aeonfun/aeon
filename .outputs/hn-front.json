hLevel":"none","matchedWords":[],"value":"jgrodziski"},"title":{"matchLevel":"none","matchedWords":[],"value":"Rediscovering the Handcart"},"url":{"matchLevel":"none","matchedWords":[],"value":"https://solar.lowtechmagazine.com/2026/04/rediscovering-the-handcart/"}},"_tags":["story","author_jgrodziski","story_47873192","front_page"],"author":"jgrodziski","children":[47908355],"created_at":"2026-04-23T07:50:17Z","created_at_i":1776930617,"num_comments":1,"objectID":"47873192","points":16,"story_id":47873192,"title":"Rediscovering the Handcart","updated_at":"2026-04-26T08:03:05Z","url":"https://solar.lowtechmagazine.com/2026/04/rediscovering-the-handcart/"},{"_highlightResult":{"author":{"matchLevel":"none","matchedWords":[],"value":"gurjeet"},"title":{"matchLevel":"none","matchedWords":[],"value":"Quirks of Human Anatomy"},"url":{"matchLevel":"none","matchedWords":[],"value":"https://www.sdbonline.org/sites/fly/lewheldquirk/figlegq6.htm"}},"_tags":["story","author_gurjeet","story_47898660","front_page"],"author":"gurjeet","children":[47908283],"created_at":"2026-04-25T04:31:14Z","created_at_i":1777091474,"num_comments":1,"objectID":"47898660","points":15,"story_id":47898660,"title":"Quirks of Human Anatomy","updated_at":"2026-04-26T08:03:05Z","url":"https://www.sdbonline.org/sites/fly/lewheldquirk/figlegq6.htm"},{"_highlightResult":{"author":{"matchLevel":"none","matchedWords":[],"value":"ahlCVA"},"title":{"matchLevel":"none","matchedWords":[],"value":"Conway's Game of Life, in real life"},"url":{"matchLevel":"none","matchedWords":[],"value":"https://lcamtuf.coredump.cx/blog/conway/"}},"_tags":["story","author_ahlCVA","story_47439821","front_page"],"author":"ahlCVA","children":[47472710],"created_at":"2026-03-19T14:11:56Z","created_at_i":1773929516,"num_comments":1,"objectID":"47439821","points":12,"story_id":47439821,"title":"Conway's Game of Life, in real life","updated_at":"2026-03-23T22:52:37Z","url":"https://lcamtuf.coredump.cx/blog/conway/"},{"_highlightResult":{"author":{"matchLevel":"none","matchedWords":[],"value":"subset"},"title":{"matchLevel":"none","matchedWords":[],"value":"Exposing Floating Point \u2013 Bartosz Ciechanowski"},"url":{"matchLevel":"none","matchedWords":[],"value":"https://ciechanow.ski/exposing-floating-point/"}},"_tags":["story","author_subset","story_47908139","front_page"],"author":"subset","children":[47908300],"created_at":"2026-04-26T07:19:20Z","created_at_i":1777187960,"num_comments":1,"objectID":"47908139","points":9,"story_id":47908139,"title":"Exposing Floating Point \u2013 Bartosz Ciechanowski","updated_at":"2026-04-26T08:03:05Z","url":"https://ciechanow.ski/exposing-floating-point/"},{"_highlightResult":{"author":{"matchLevel":"none","matchedWords":[],"value":"dimastopel"},"story_text":{"matchLevel":"none","matchedWords":[],"value":"Back in 2012 I built <a href=\"https://cert-depot.com\" rel=\"nofollow\">https://cert-depot.com</a> as a weekend project. Node.js + Express + jQuery, shelling out to OpenSSL for certificate generation. It worked but I eventually let it rot. <a href=\"https://news.ycombinator.com/item?id=4766743\">https://news.ycombinator.com/item?id=4766743</a><p>Rewrote it from scratch in Go. The entire thing is a single binary with no external dependencies:<p>1. Certificate generation uses Go's crypto/x509 (no OpenSSL)<p>2. Certificates are generated in memory and streamed directly \u2014 nothing is stored on the server<p>3. RSA 2048/4096 and ECDSA P-256/P-384<p>4. Subject Alternative Names (required by browsers since Chrome 58)<p>5. ZIP (PEM files) or PFX/PKCS#12 output<p>You comments / suggestions / bug reports are very welcome. Thanks.<p>Source: <a href=\"https://github.com/dimastopel/certdepot\" rel=\"nofollow\">https://github.com/dimastopel/certdepot</a>"},"title":{"matchLevel":"none","matchedWords":[],"value":"Show HN: I rewrote my 2012 self-signed cert generator in Go \u2013 cert-depot.com"}},"_tags":["story","author_dimastopel","story_47613622","show_hn","front_page"],"author":"dimastopel","children":[47618945],"created_at":"2026-04-02T12:36:10Z","created_at_i":1775133370,"num_comments":1,"objectID":"47613622","points":9,"story_id":47613622,"story_text":"Back in 2012 I built <a href=\"https:&#x2F;&#x2F;cert-depot.com\" rel=\"nofollow\">https:&#x2F;&#x2F;cert-depot.com</a> as a weekend project. Node.js + Express + jQuery, shelling out to OpenSSL for certificate generation. It worked but I eventually let it rot. <a href=\"https:&#x2F;&#x2F;news.ycombinator.com&#x2F;item?id=4766743\">https:&#x2F;&#x2F;news.ycombinator.com&#x2F;item?id=4766743</a><p>Rewrote it from scratch in Go. The entire thing is a single binary with no external dependencies:<p>1. Certificate generation uses Go&#x27;s crypto&#x2F;x509 (no OpenSSL)<p>2. Certificates are generated in memory and streamed directly \u2014 nothing is stored on the server<p>3. RSA 2048&#x2F;4096 and ECDSA P-256&#x2F;P-384<p>4. Subject Alternative Names (required by browsers since Chrome 58)<p>5. ZIP (PEM files) or PFX&#x2F;PKCS#12 output<p>You comments &#x2F; suggestions &#x2F; bug reports are very welcome. Thanks.<p>Source: <a href=\"https:&#x2F;&#x2F;github.com&#x2F;dimastopel&#x2F;certdepot\" rel=\"nofollow\">https:&#x2F;&#x2F;github.com&#x2F;dimastopel&#x2F;certdepot</a>","title":"Show HN: I rewrote my 2012 self-signed cert generator in Go \u2013 cert-depot.com","updated_at":"2026-04-06T06:43:48Z"}],"hitsPerPage":30,"nbHits":79,"nbPages":3,"page":0,"params":"tags=front_page&hitsPerPage=30&advancedSyntax=true&analyticsTags=backend","processingTimeMS":1,"processingTimingsMS":{"_request":{"roundTrip":21},"total":1},"query":"","serverTimeMS":2}
