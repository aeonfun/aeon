ess":"0xa0de9908fb5a770ca44bf29ec6d41a38f15f8561","createdAt":"2026-05-06T10:00:52.064089Z","updatedAt":"2026-05-06T10:01:00.068989Z","profile":{"name":"moonlight2020","pseudonym":"Whimsical-Quote","displayUsernamePublic":true,"bio":"","proxyWallet":"0x407dd149f1e92c91d0053e0240e03318a1e01bae","baseAddress":"0x473d1a277071cfdca78fd23269faa69b4cdc1c9f","profileImage":"https://polymarket-upload.s3.us-east-2.amazonaws.com/profile-image-7121973-3c401847-007f-4954-b10f-85aca673df40.webp"},"reactions":[{"id":"2841053","commentID":2887943,"reactionType":"HEART","userAddress":"0xa0de9908fb5a770ca44bf29ec6d41a38f15f8561","profile":{"proxyWallet":"0x624d59e1f4d36cc96c419b9c7a844bd879976ea6"}},{"id":"2841054","commentID":2887943,"reactionType":"HEART","userAddress":"0xa0de9908fb5a770ca44bf29ec6d41a38f15f8561","profile":{"proxyWallet":"0x624d59e1f4d36cc96c419b9c7a844bd879976ea6"}}],"reportCount":0,"reactionCount":2},{"id":"2887948","body":"bless you","parentEntityType":"Event","parentEntityID":357807,"parentCommentID":"2887933","userAddress":"0xa0de9908fb5a770ca44bf29ec6d41a38f15f8561","replyAddress":"0x473d1a277071cfdca78fd23269faa69b4cdc1c9f","createdAt":"2026-05-06T10:03:07.205228Z","updatedAt":"2026-05-06T10:03:15.552664Z","profile":{"name":"nunclearra92","pseudonym":"Ill-Fated-Defender","displayUsernamePublic":true,"proxyWallet":"0x624d59e1f4d36cc96c419b9c7a844bd879976ea6","baseAddress":"0xa0de9908fb5a770ca44bf29ec6d41a38f15f8561"},"reportCount":0,"reactionCount":0},{"id":"2887888","body":"A 30-day negotiation period would begin, likely in Geneva or Islamabad, with both sides gradually rolling back military and shipping restrictions. Iran would also accept tougher UN inspections and pledge not to pursue nuclear weapons.","parentEntityType":"Event","parentEntityID":357807,"userAddress":"0x4ae3e2328f27779ad7ee7286e864226be52aface","createdAt":"2026-05-06T09:41:21.309857Z","updatedAt":"2026-05-06T09:41:28.543219Z","profile":{"name":"jsbo","pseudonym":"Keen-Image","displayUsernamePublic":true,"proxyWallet":"0x5a353f5dfbcf9351355854344a2c975ce2245732","baseAddress":"0x4ae3e2328f27779ad7ee7286e864226be52aface"},"reportCount":0,"reactionCount":0},{"id":"2887885","body":"The rules are very strict on two key points. First: it needs to be an agreement that explicitly indicates that military hostilities have ended permanently or on a \"lasting basis.\" Second: temporary extensions or non definitive agreements do not qualify. The one page MOU under discussion does exactly what the rules exclude: it declares the end of the war, but then opens a 30day window to negotiate the actual detailed agreement. Many clauses are contingent on reaching that final agreement  so in spirit it's more of a framework than a permanent peace. A strict resolver would almost certainly say \"No.\" A generous resolver might say \"Yes\" if the MOU contains language like \"permanent end of hostilities,\" but that's a bet on interpretation, not on facts.","parentEntityType":"Event","parentEntityID":357807,"userAddress":"0x528ee4d2a018d8bd4dab489e1424b93c6db1c916","createdAt":"2026-05-06T09:39:09.364959Z","updatedAt":"2026-05-06T09:39:18.08404Z","profile":{"name":"LKFen","pseudonym":"Clever-Selfesteem","displayUsernamePublic":true,"bio":"","proxyWallet":"0xb520524a6299b6e188da9343c92267443b61c3d0","baseAddress":"0x528ee4d2a018d8bd4dab489e1424b93c6db1c916","profileImage":"https://polymarket-upload.s3.us-east-2.amazonaws.com/profile-image-3114786-064a4bcc-5796-4dbe-a723-306a970fefc5.jpg"},"reactions":[{"id":"2841028","commentID":2887885,"reactionType":"HEART","userAddress":"0x4ae3e2328f27779ad7ee7286e864226be52aface","profile":{"proxyWallet":"0x5a353f5dfbcf9351355854344a2c975ce2245732"}},{"id":"2841035","commentID":2887885,"reactionType":"HEART","userAddress":"0x5dfeecd3af4258c1a0fd0890c1b6ffefc0292673","profile":{"proxyWallet":"0x8a37bbf79eba56e84beb04a270d62da2424ea71d"}},{"id":"2841036","commentID":2887885,"reactionType":"HEART","userAddress":"0x5dfeecd3af4258c1a0fd0890c1b6