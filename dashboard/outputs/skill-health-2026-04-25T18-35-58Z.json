      },
      "children": []
    },
    "heartbeat-progress": {
      "type": "Progress",
      "props": {
        "value": 67,
        "max": 100,
        "label": "Success rate"
      },
      "children": []
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
