{
  "root": "card-main",
  "state": {},
  "elements": {
    "card-main": {
      "type": "Card",
      "props": {
        "title": "Skill Health"
      },
      "children": [
        "date-header",
        "sep1",
        "warning-section",
        "sep2",
        "nodata-section",
        "sep3",
        "healthy-stat",
        "sep4",
        "issues-section"
      ]
    },
    "date-header": {
      "type": "Heading",
      "props": {
        "text": "2026-04-25 — WARNING(1)",
        "level": "h2"
      },
      "children": []
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      },
      "children": []
