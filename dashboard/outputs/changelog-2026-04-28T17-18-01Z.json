{
  "root": "card",
  "state": {},
  "elements": {
    "card": {
      "type": "Card",
      "props": {
        "title": "Changelog — Week of 2026-04-28"
      },
      "children": [
        "main-stack"
      ]
    },
    "main-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "summary-stack",
        "breakdown-grid",
        "separator",
        "highlight-text",
        "article-link"
      ]
    },
    "summary-stack": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "md"
      },
      "children": [
        "stat-repos",
        "stat-changes"
      ]
    },
    "stat-repos": {
      "type": "Stat",
      "props": {
        "label": "Repository",
        "value": "1"
      }
    },
    "stat-changes": {
      "type": "Stat",
      "props": {
        "label": "User-Facing Changes",
        "value": "8"
      }
    },
    "breakdown-grid": {
      "type": "Grid",
      "props": {
        "columns": 4,
        "gap": "md"
      },
      "children": [
        "stat-breaking",
        "stat-added",
        "stat-fixed",
        "stat-security"
      ]
    },
    "stat-breaking": {
      "type": "Stat",
      "props": {
        "label": "Breaking",
        "value": "0"
      }
    },
    "stat-added": {
      "type": "Stat",
      "props": {
        "label": "Added",
        "value": "8"
      }
    },
    "stat-fixed": {
      "type": "Stat",
      "props": {
        "label": "Fixed",
        "value": "0"
      }
    },
    "stat-security": {
      "type": "Stat",
      "props": {
        "label": "Security",
        "value": "0"
      }
    },
    "separator": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "highlight-text": {
      "type": "Text",
      "props": {
        "text": "Every fork now gets a public /status/ health dashboard, extended today with a Token Pulse row.",
