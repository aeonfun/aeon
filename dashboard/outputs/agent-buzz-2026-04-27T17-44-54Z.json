      }
    },
    "text-sandbox": {
      "type": "Text",
      "props": {
        "text": "curl env-var blocked by sandbox"
      }
    },
    "text-webfetch": {
      "type": "Text",
      "props": {
        "text": "WebFetch is GET-only so cannot POST to X.AI responses"
      }
    },
    "text-websearch": {
      "type": "Text",
      "props": {
        "text": "WebSearch returned only stale or non-tweet results"
      }
    },
    "separator-2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "stack-issue": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "heading-issue",
        "text-issue"
      ]
