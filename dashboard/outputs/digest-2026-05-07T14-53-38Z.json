    "item1_heading": {
      "type": "Heading",
      "props": {
        "text": "SEC pauses 24 prediction-market ETFs days before Roundhill's May-7 launch",
        "level": "h3"
      },
      "children": []
    },
    "item1_description": {
      "type": "Text",
      "props": {
        "text": "The SEC invoked its 75-day extension on event-contract ETFs from Roundhill, Bitwise, and GraniteShares, freezing the retail-wrapper category before any product traded. Roundhill's first fund had been scheduled to launch May 7. No redo deadline; the SEC said it is \"actively engaged\" with sponsors."
      },
      "children": []
