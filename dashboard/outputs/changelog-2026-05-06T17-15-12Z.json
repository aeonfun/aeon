      "props": {
        "text": "Change Breakdown",
        "level": "h3"
      }
    },
    "breakdown-grid": {
      "type": "Grid",
      "props": {
        "columns": 5,
        "gap": "md"
      },
      "children": [
        "stat-breaking",
        "stat-added",
        "stat-changed",
        "stat-fixed",
        "stat-security"
      ]
    },
    "stat-breaking": {
      "type": "Stat",
      "props": {
        "value": "0",
        "label": "Breaking"
      }
    },
    "stat-added": {
      "type": "Stat",
      "props": {
        "value": "18",
        "label": "Added"
      }
    },
    "stat-changed": {
      "type": "Stat",
      "props": {
        "value": "3",
        "label": "Changed"
      }
    },
    "stat-fixed": {
      "type": "Stat",
      "props": {
        "value": "4",
        "label": "Fixed"
      }
    },
    "stat-security": {
      "type": "Stat",
      "props": {
        "value": "2",
        "label": "Security"
      }
    },
    "separator-2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "highlights-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
