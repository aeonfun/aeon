{
  "root": "card-main",
  "state": {},
  "elements": {
    "card-main": {
      "type": "Card",
      "props": {
        "title": "Changelog — Week of 2026-05-06"
      },
      "children": [
        "summary-stack",
        "separator-1",
        "breakdown-stack",
        "separator-2",
        "highlights-stack",
        "separator-3",
        "link-stack"
      ]
    },
    "summary-stack": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "md"
      },
      "children": [
        "stat-repos",
        "stat-changes"
      ]
    },
    "stat-repos": {
      "type": "Stat",
      "props": {
        "value": "3",
        "label": "Repos"
      }
    },
    "stat-changes": {
      "type": "Stat",
      "props": {
        "value": "23",
        "label": "User-facing changes"
      }
    },
    "separator-1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "breakdown-stack": {
      "type": "Stack",
