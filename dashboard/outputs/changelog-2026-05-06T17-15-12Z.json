      }
    },
    "separator-3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "link-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "full-changelog-link"
