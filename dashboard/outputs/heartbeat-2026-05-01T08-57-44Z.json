    "task1": {
      "type": "Text",
      "props": {
        "text": "07:00 morning chain"
      }
    },
    "task2": {
      "type": "Text",
      "props": {
        "text": "07:30 telegram"
      }
    },
    "task3": {
      "type": "Text",
      "props": {
        "text": "08:00 heartbeat"
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
