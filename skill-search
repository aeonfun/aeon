#!/usr/bin/env bash
# skill-search — Query the Aeon skill catalog by natural-language description.
#
# Reads docs/skills-index.json (generated by ./index-skills) and returns the
# ranked top-K skills closest to the query, by cosine similarity in embedding
# space.
#
# Usage:
#   ./skill-search "track new GitHub stars"
#   ./skill-search "monitor DeFi protocols" --limit 5
#   ./skill-search "research papers" --type research --format json
#
# Provider: uses the same provider used to build the index (recorded in
# docs/skills-index.json). Inside the Sealed Sprint, that's `mock` —
# deterministic and offline. Post-seal, regenerate the index with a real
# provider and queries embed against that.

set -eo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"

QUERY=""
LIMIT=5
TAG_FILTER=""
FORMAT="md"

while [ $# -gt 0 ]; do
  case "$1" in
    --limit)  LIMIT="$2"; shift 2 ;;
    --type)   TAG_FILTER="$2"; shift 2 ;;
    --format) FORMAT="$2"; shift 2 ;;
    -h|--help)
      awk '/^#/{print substr($0,3)} !/^#/{exit}' "$0"
      exit 0
      ;;
    *)
      if [ -z "$QUERY" ]; then QUERY="$1"; else QUERY="$QUERY $1"; fi
      shift
      ;;
  esac
done

if [ -z "$QUERY" ]; then
  echo "usage: ./skill-search \"<query>\" [--limit N] [--type <tag>] [--format md|json]" >&2
  exit 2
fi

AEON_ROOT="$ROOT" QUERY="$QUERY" LIMIT="$LIMIT" TAG_FILTER="$TAG_FILTER" FORMAT="$FORMAT" \
  node "$ROOT/scripts/skill-search.mjs"
